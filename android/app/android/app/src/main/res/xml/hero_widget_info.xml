<?xml version="1.0" encoding="utf-8"?>
<!-- AppWidgetProviderInfo for the 4x2 "hero" Now Playing widget: album art +
     title/artist + animated gradient waveform + progress + transport, with an
     idle "Start listening" state. Default 4x2, resizable. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/hero_widget"
    android:previewLayout="@layout/hero_widget"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen" />
