<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded tile with a ~2dp magenta->violet gradient border and a near-black
     interior — the hero widget frame. Layer-list: a gradient-filled rounded
     rect underneath, and a dark rounded rect inset by 2dp on top, so only the
     2dp rim shows the gradient. (A <shape> stroke can't itself be a gradient,
     hence the two-layer trick.) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#F533C8"
                android:centerColor="#A93CF2"
                android:endColor="#6F4BF5"
                android:angle="315" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#0A0A0A" />
            <corners android:radius="26dp" />
        </shape>
    </item>
</layer-list>
