<?xml version="1.0" encoding="utf-8"?>
<!-- Divider next to the heerr logo. Tapers to a point at both the top and
     the bottom (widest in the middle) and fades out via alpha at both ends,
     using the heerr brand gradient (magenta -> purple -> violet, see
     lib/theme.dart heerrGradient). Requires API 24+ to render the vector
     gradient fill on-device; falls back to a solid black taper on older
     widget hosts. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="2dp"
    android:height="52dp"
    android:viewportWidth="10"
    android:viewportHeight="260">
    <path android:pathData="M5,0 L8,40 L8,220 L5,260 L2,220 L2,40 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="5"
                android:startY="0"
                android:endX="5"
                android:endY="260">
                <item android:offset="0.0" android:color="#00F533C8" />
                <item android:offset="0.2" android:color="#FFF533C8" />
                <item android:offset="0.5" android:color="#FFA93CF2" />
                <item android:offset="0.8" android:color="#FF6F4BF5" />
                <item android:offset="1.0" android:color="#006F4BF5" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
