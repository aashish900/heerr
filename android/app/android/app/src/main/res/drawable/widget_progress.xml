<?xml version="1.0" encoding="utf-8"?>
<!-- Display-only playback progress track. Dark rounded track with a
     magenta->violet gradient rounded fill (heerr brand). Position is pushed
     from Dart; the bar is not seekable (no touch on a ProgressBar in
     RemoteViews). -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="#2E2E2E" />
            <corners android:radius="100dp" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <gradient
                    android:startColor="#F533C8"
                    android:centerColor="#A93CF2"
                    android:endColor="#6F4BF5"
                    android:angle="0" />
                <corners android:radius="100dp" />
            </shape>
        </clip>
    </item>
</layer-list>
