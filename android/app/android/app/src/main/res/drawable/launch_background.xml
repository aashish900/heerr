<?xml version="1.0" encoding="utf-8"?>
<!-- Branded launch splash — plain black previously (unmodified Flutter
     template default), which was indistinguishable from a hung/broken app
     during the native init window (AudioService.init() etc.) before
     runApp()'s first frame. Reuses the adaptive-icon foreground so the
     splash at least shows the heerr mark while loading. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/black" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/ic_launcher_foreground" />
    </item>
</layer-list>
