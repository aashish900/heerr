<?xml version="1.0" encoding="utf-8"?>
<!-- 4x2 "hero" Now Playing widget. One layout, two states toggled by the
     provider off np_has_track:
       - hero_idle_group   : gradient heerr logo + "Start listening…" prompt.
       - hero_playing_group: album art + title/artist + animated gradient
                             waveform + display-only progress + m:ss times.
     The transport row (prev / play-pause / next) is SHARED across both states
     so the control ids appear once (no duplicate-id ambiguity in RemoteViews);
     the provider swaps the play button's background to the gradient disc in the
     playing state. Uses only RemoteViews-whitelisted classes (LinearLayout /
     FrameLayout / ViewFlipper / ImageView / ImageButton / TextView /
     ProgressBar) — never a bare <View>. Field ids must match HeroWidgetProvider.kt. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:background="@drawable/widget_gradient_border"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Left content area: idle prompt or playing details, stacked; the
             provider makes exactly one visible. -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <!-- IDLE -->
            <LinearLayout
                android:id="@+id/hero_idle_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="52dp"
                    android:layout_height="46dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/widget_logo_gradient"
                    android:contentDescription="heerr" />

                <LinearLayout
                    android:layout_width="1dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="14dp"
                    android:background="#2E2E2E" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:text="heerr" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:textColor="#B0B0B0"
                        android:textSize="13sp"
                        android:text="Start listening to your music" />
                </LinearLayout>
            </LinearLayout>

            <!-- PLAYING -->
            <LinearLayout
                android:id="@+id/hero_playing_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/widget_art"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/widget_ic_album"
                    android:contentDescription="Album art" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/widget_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:text="heerr" />

                    <TextView
                        android:id="@+id/widget_artist"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textColor="#B0B0B0"
                        android:textSize="13sp"
                        android:text="Nothing playing" />

                    <!-- Animated waveform (while playing) over a static frame
                         (while paused); the provider toggles their visibility
                         off np_playing. -->
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="22dp"
                        android:layout_marginTop="6dp">

                        <ViewFlipper
                            android:id="@+id/widget_wave"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:autoStart="true"
                            android:flipInterval="120"
                            android:measureAllChildren="true">
                            <ImageView android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter"
                                android:src="@drawable/widget_wave_1"
                                android:contentDescription="Playing" />
                            <ImageView android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter" android:src="@drawable/widget_wave_2" />
                            <ImageView android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter" android:src="@drawable/widget_wave_3" />
                            <ImageView android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter" android:src="@drawable/widget_wave_4" />
                            <ImageView android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter" android:src="@drawable/widget_wave_5" />
                            <ImageView android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter" android:src="@drawable/widget_wave_6" />
                            <ImageView android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter" android:src="@drawable/widget_wave_7" />
                            <ImageView android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="fitCenter" android:src="@drawable/widget_wave_8" />
                        </ViewFlipper>

                        <ImageView
                            android:id="@+id/widget_wave_static"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:visibility="gone"
                            android:src="@drawable/widget_wave_3"
                            android:contentDescription="Paused" />
                    </FrameLayout>

                    <ProgressBar
                        android:id="@+id/widget_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="8dp"
                        android:max="1000"
                        android:progress="0"
                        android:progressDrawable="@drawable/widget_progress" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/widget_time_pos"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="start"
                            android:textColor="#B0B0B0"
                            android:textSize="11sp"
                            android:text="0:00" />

                        <TextView
                            android:id="@+id/widget_time_dur"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:textColor="#B0B0B0"
                            android:textSize="11sp"
                            android:text="0:00" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- Shared transport row. The provider sets the play button's
             background to the gradient disc in the playing state and clears it
             (flat glyph) in the idle state. -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp">

            <ImageButton
                android:id="@+id/widget_prev"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:src="@drawable/widget_ic_previous"
                android:contentDescription="Previous" />

            <ImageButton
                android:id="@+id/widget_play_pause"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                android:padding="13dp"
                android:src="@drawable/widget_ic_play"
                android:contentDescription="Play/Pause" />

            <ImageButton
                android:id="@+id/widget_next"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:src="@drawable/widget_ic_next"
                android:contentDescription="Next" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
