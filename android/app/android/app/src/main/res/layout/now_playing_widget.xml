<?xml version="1.0" encoding="utf-8"?>
<!-- #20: compact single-row "Now Playing" widget. Only RemoteViews-allowed
     classes (LinearLayout / TextView / ProgressBar / ImageButton) — no bare
     View, no ImageView/bitmap (those caused the blank-widget bugs; see
     DEBT.md #20). Field ids must match the keys NowPlayingWidgetProvider.kt
     reads from the home_widget data. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_background"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="heerr" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#B0B0B0"
            android:textSize="12sp"
            android:text="Nothing playing" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/widget_prev"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:padding="9dp"
        android:scaleType="fitCenter"
        android:background="@android:color/transparent"
        android:src="@drawable/widget_ic_previous"
        android:contentDescription="Previous" />

    <ImageButton
        android:id="@+id/widget_play_pause"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:padding="7dp"
        android:scaleType="fitCenter"
        android:background="@android:color/transparent"
        android:src="@drawable/widget_ic_play"
        android:contentDescription="Play or pause" />

    <ImageButton
        android:id="@+id/widget_next"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:padding="9dp"
        android:scaleType="fitCenter"
        android:background="@android:color/transparent"
        android:src="@drawable/widget_ic_next"
        android:contentDescription="Next" />
</LinearLayout>
