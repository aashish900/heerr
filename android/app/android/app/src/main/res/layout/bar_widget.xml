<?xml version="1.0" encoding="utf-8"?>
<!-- Thin "bar" Now Playing widget (3x1 / 4x1). The visible tile is centred at
     ~50% of the cell height via weighted empty spacers (RemoteViews has no
     percent height). Layout: animated waveform (left) + inline title/artist
     (centre) + display-only progress bar (right). Uses only RemoteViews-
     whitelisted classes (LinearLayout / ViewFlipper / ImageView / TextView /
     ProgressBar). Field ids must match the keys BarWidgetProvider.kt reads. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Top spacer: ~25% of the cell height. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- The visible tile: ~50% of the cell height. -->
    <LinearLayout
        android:id="@+id/widget_root"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@drawable/widget_background">

        <!-- Animated waveform (while playing) overlaid on a static frame
             (while paused). The provider toggles their visibility off the
             np_playing flag so the bars move only during playback — the only
             "sync" a home-screen widget can express (no live-amplitude API). -->
        <FrameLayout
            android:layout_width="30dp"
            android:layout_height="22dp">

            <ViewFlipper
                android:id="@+id/widget_wave"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:autoStart="true"
                android:flipInterval="120"
                android:measureAllChildren="true">
                <ImageView android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@drawable/widget_wave_1"
                    android:contentDescription="Playing" />
                <ImageView android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" android:src="@drawable/widget_wave_2" />
                <ImageView android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" android:src="@drawable/widget_wave_3" />
                <ImageView android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" android:src="@drawable/widget_wave_4" />
                <ImageView android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" android:src="@drawable/widget_wave_5" />
                <ImageView android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" android:src="@drawable/widget_wave_6" />
                <ImageView android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" android:src="@drawable/widget_wave_7" />
                <ImageView android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" android:src="@drawable/widget_wave_8" />
            </ViewFlipper>

            <ImageView
                android:id="@+id/widget_wave_static"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:visibility="gone"
                android:src="@drawable/widget_wave_3"
                android:contentDescription="Paused" />
        </FrameLayout>

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="heerr" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#B0B0B0"
            android:textSize="12sp"
            android:text="Nothing playing" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="110dp"
            android:layout_height="6dp"
            android:layout_marginStart="12dp"
            android:max="1000"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress" />
    </LinearLayout>

    <!-- Bottom spacer: ~25% of the cell height. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
