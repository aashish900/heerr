<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- audio_service (J1) requires a foreground service so playback survives
         the app being backgrounded. POST_NOTIFICATIONS is Android 13+; the
         foreground notification still shows on older releases without it. -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Q1: WorkManager-driven background offline sync. RECEIVE_BOOT_COMPLETED
         is what makes scheduled periodic work survive a device reboot — the
         workmanager plugin itself supplies the WorkManager Initializer
         content-provider via manifest merge, so no <provider> entry is needed
         here. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- V1 (back-stack fix): opt out of Android predictive back. At
         targetSdk 36 predictive back is on by default, and the shell's
         PopScope lives on the ROOT navigator's route while go_router's
         nested ShellRoute navigator (one page per tab, no PopScope of its
         own) dispatches NavigationNotification(canHandlePop: false) after
         every tab switch — clobbering the PopScope's doNotPop notification.
         Flutter then reports setFrameworkHandlesBack(false), so the OS
         finishes the Activity itself and the PopScope callback never runs.
         Opting out restores the legacy KEYCODE_BACK → onBackPressed →
         "popRoute" channel path, where the PopScope works (and is what
         router_test.dart's handlePopRoute() tests exercise). -->
    <application
        android:label="heerr"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:enableOnBackInvokedCallback="false"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- audio_service foreground service. Hosts the just_audio player
             so playback continues when the app is backgrounded or screen-off.
             foregroundServiceType="mediaPlayback" is required on Android 14+. -->
        <service
            android:name="com.ryanheise.audioservice.AudioService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true">
            <intent-filter>
                <action android:name="android.media.browse.MediaBrowserService"/>
            </intent-filter>
        </service>

        <!-- Hardware media-button receiver — Bluetooth headset play/pause,
             car infotainment controls, etc. -->
        <receiver
            android:name="com.ryanheise.audioservice.MediaButtonReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON"/>
            </intent-filter>
        </receiver>

        <!-- #20: Now Playing home-screen widget — the 4x2 "hero" tile: album
             art + title/artist + animated gradient waveform + progress +
             m:ss times + transport, with an idle "Start listening" state.
             Display state is pushed from Dart via the home_widget package;
             transport buttons broadcast ACTION_MEDIA_BUTTON to the
             MediaButtonReceiver above. (The earlier "classic"/"bar"/"pill"
             widgets were retired in favour of this single tile.) -->
        <receiver
            android:name=".HeroWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/hero_widget_info" />
        </receiver>

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
