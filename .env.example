# heerr backend — environment template.
# Copy to `.env` next to `docker-compose.snippet.yml`; fill in real values.
# Never commit the populated `.env` (root .gitignore excludes it).
#
# Read by:
#   - docker-compose (env_file: .env on every service)
#   - Backend container's pydantic-settings (Settings in app/config.py)

# === Postgres ===============================================================
# Used both by the postgres container (to bootstrap on first start) AND by the
# backend container (via DATABASE_URL). Keep the three values consistent with
# the DATABASE_URL below.
POSTGRES_USER=music_request_app
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=music_request

# === Backend ================================================================
# Async driver (asyncpg) for the FastAPI app. Host is `postgres` because that
# is the compose service name and resolves on the arr-stack docker network.
DATABASE_URL=postgresql+asyncpg://music_request_app:change-me-strong-password@postgres:5432/music_request

# Where spotDL writes downloaded files. Mounted into the backend container at
# the same path; Navidrome (a sibling on the arr-stack) indexes this dir.
MUSIC_OUTPUT_DIR=/data/media/music

# Optional: override the spotdl binary location (default
# `/opt/spotdl-venv/bin/spotdl`, set inside the image). Only override if you
# install spotdl somewhere else.
# SPOTDL_EXECUTABLE=/opt/spotdl-venv/bin/spotdl

# === Preview stream proxy (Phase K) =========================================
# GET /api/v1/preview/stream resolves a YouTube Music track to its audio URL
# (yt-dlp) and proxies the bytes to the device over Tailscale, so a search
# result can be streamed before it is downloaded into Navidrome. Set
# PREVIEW_ENABLED=false to disable the endpoint (it returns 404) — the operator
# kill switch for the one feature that pulls from googlevideo. Both optional;
# defaults shown.
# PREVIEW_ENABLED=true
# PREVIEW_CACHE_TTL_S=300

# === Lyrics embedding (Phase L) =============================================
# When true, passes `--lyrics` to spotdl so downloaded MP3s carry embedded
# lyrics from spotdl's default providers (Genius, AZLyrics, etc.). Optional;
# default shown.
# SPOTDL_EMBED_LYRICS=false

# === Navidrome (identity provider) ==========================================
# Where the backend reaches your Navidrome instance over the tailnet. heerr
# delegates authentication to Navidrome via Subsonic `ping.view` — heerr stores
# no passwords. Required at startup (POST /auth/login fails fast if unset).
# Use the tailnet IP or MagicDNS name; never a public URL.
NAVIDROME_URL=http://navidrome.example.tailnet:4533

# Where the music library is mounted inside NAVIDROME's container (Phase N2).
# Navidrome must run with `Subsonic.DefaultReportRealPath=true`
# (ND_SUBSONIC_DEFAULTREPORTREALPATH) so the Subsonic API reports real paths —
# it reports them absolute under this prefix (e.g. /music/<file>), and
# DELETE /library/song strips the prefix before resolving under
# MUSIC_OUTPUT_DIR. Optional; default shown.
# NAVIDROME_MUSIC_FOLDER=/music

# === Recommendations ========================================================
# Selects the recommendation engine for POST /api/v1/recommend. Default is
# `ytmusic` (zero-credential). Comma-separated values (e.g. `lastfm,ytmusic`)
# enable a fallback chain — first engine that returns results wins. See
# backend/docs/ROADMAP.md Phase I for the engine catalogue.
RECOMMENDATION_ENGINE=ytmusic

# === Last.fm (only when RECOMMENDATION_ENGINE includes `lastfm`) ============
# Register a free API key at https://www.last.fm/api/account/create. Required
# at startup when the lastfm engine is selected — the factory raises if it is
# missing or empty.
LASTFM_API_KEY=

# Optional global fallback: when set, the lastfm engine augments client-supplied
# seeds with the user's top tracks from the last month (Last.fm `user.getTopTracks?
# period=1month&limit=10`). Lets recommendations work even when the client sends
# an empty seeds list. Leave blank to disable.
# Per-user override: a user can set their own `lastfm_username` via PATCH /settings
# (DEBT M5) — the per-user value wins; this env var is the fallback when unset.
LASTFM_USERNAME=

# === ListenBrainz (only when RECOMMENDATION_ENGINE includes `listenbrainz`) =
# Free user token from https://listenbrainz.org/profile/ (Settings → Create
# token). Global fallback for the listenbrainz engine; the engine derives the
# username from the token via the /1/validate-token API. Useful only after the
# Android client (N1) has been scrobbling for ≥ 1 week so ListenBrainz has
# listen history to recommend against.
# Per-user override: a user can set their own `listenbrainz_token` via
# PATCH /settings (DEBT M5) — the per-user value wins. With multiple users each
# should set their own token here-or-via-settings, since the token IS the
# identity whose history drives recommendations. Leave blank if every user sets
# their own via /settings.
LISTENBRAINZ_USER_TOKEN=

# === Podcasts (Phase P, #53) =================================================
# Free key+secret from https://podcastindex.org/developer — used to sign
# POST /api/v1/podcasts/search requests (HMAC-ish: sha1(key+secret+timestamp)).
# Optional at the Settings level so installs without the podcast feature don't
# fail to boot; PodcastIndexClient raises a clear 502 at call time if unset.
# PODCASTINDEX_KEY=
# PODCASTINDEX_SECRET=

# Where downloaded podcast episodes are written. Deliberately NOT
# MUSIC_OUTPUT_DIR — Navidrome does not watch this directory; the backend
# serves episode audio itself (GET /podcasts/episodes/{id}/audio, Phase P6).
# Optional; default shown.
# PODCAST_OUTPUT_DIR=/data/media/podcasts
